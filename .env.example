# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=your_strong_password_here

# ── API / Backend ─────────────────────────────────────────────────────────────
# REQUIRED: At least 32 random characters
JWT_SECRET=REPLACE_WITH_MINIMUM_32_CHAR_RANDOM_SECRET_KEY_HERE

# ── URLs ──────────────────────────────────────────────────────────────────────
API_BASE_URL=https://api.sacredvibesyoga.com
FRONTEND_URL=https://sacredvibesyoga.com

# ── Square (Payment Processing) ───────────────────────────────────────────────
# Get from: https://developer.squareup.com/apps
# Use 'sandbox' for testing, 'production' for live
SQUARE_ENVIRONMENT=sandbox
SQUARE_APP_ID=
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
# Get from Square Developer Dashboard > Webhooks
SQUARE_WEBHOOK_KEY=

# ── Stripe (Contact Import Only — NOT payments) ───────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.youremailprovider.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=info@sacredvibesyoga.com
